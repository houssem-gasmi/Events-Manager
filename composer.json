{
    "name": "app/projet-symfony-evenements",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/doctrine-bundle": "^2.12",
        "doctrine/migrations": "3.8",
        "doctrine/orm": "^2.20",
        "symfony/doctrine-bridge": "^6.4",
        "symfony/dotenv": "^6.4",
        "symfony/error-handler": "^6.4",
        "symfony/form": "^6.4",
        "symfony/framework-bundle": "^6.4",
        "symfony/http-foundation": "^6.4",
        "symfony/http-kernel": "^6.4",
        "symfony/mailer": "6.4",
        "symfony/routing": "^6.4",
        "symfony/runtime": "^6.4",
        "symfony/security-bundle": "^6.4",
        "symfony/string": "^6.4",
        "symfony/twig-bundle": "^6.4",
        "symfony/validator": "^6.4",
        "symfony/var-exporter": "^6.4",
        "symfony/yaml": "^7.4"
    },
    "require-dev": {
        "symfony/maker-bundle": "^1.52"
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "6.4.*"
        }
    }
}
