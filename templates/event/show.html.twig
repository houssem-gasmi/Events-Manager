{% extends 'base.html.twig' %}

{% block title %}{{ event.title }}{% endblock %}

{% block body %}
<div class="row">
    <div class="col-lg-8">
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <h1 class="h3">{{ event.title }}</h1>
                <p class="text-muted">{{ event.description }}</p>
                <ul class="list-unstyled">
                    <li><strong>Date:</strong> {{ event.eventDate|date('Y-m-d H:i') }}</li>
                    <li><strong>Location:</strong> {{ event.location }}</li>
                    <li><strong>Category:</strong> {{ event.category ? event.category.name : 'Uncategorized' }}</li>
                    <li><strong>Price:</strong> {{ event.price > 0 ? ((event.price / 100)|number_format(2, '.', ',')) ~ ' EUR' : 'Free' }}</li>
                    <li><strong>Seats left:</strong> {{ event.availableSeats }}</li>
                </ul>

                {% if event.hasEnded() %}
                    <div class="alert alert-secondary mb-3">
                        This event has ended, so joining is closed.
                    </div>
                {% endif %}

                {% if event.price > 0 and app.user and event.hasAttendee(app.user) %}
                    <div class="alert alert-warning mb-3">
                        Paid event. No refunds after payment, and unregister is disabled.
                    </div>
                {% endif %}

                {% if app.user and event.organizer and event.organizer.id == app.user.id %}
                    <div class="alert alert-info mb-3">
                        You are the organizer of this event, so joining is disabled.
                    </div>
                {% endif %}

                {% if app.user and event.organizer and event.organizer.id == app.user.id %}
                    <div class="d-flex gap-2">
                        <a class="btn btn-outline-primary" href="{{ path('app_event_edit', {id: event.id}) }}">Edit</a>
                        <form method="post" action="{{ path('app_event_delete', {id: event.id}) }}" onsubmit="return confirm('Delete this event?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ event.id) }}">
                            <button class="btn btn-outline-danger" type="submit">Delete</button>
                        </form>
                    </div>
                {% endif %}
            </div>
        </div>

        {% if app.user %}
            <div class="card shadow-sm mb-3">
                <div class="card-body d-flex flex-column flex-sm-row gap-2">
                    <form method="post" action="{{ path('app_event_register', {id: event.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('register' ~ event.id) }}">
                        <button class="btn btn-success w-100 w-sm-auto" type="submit" {{ event.full or event.hasAttendee(app.user) or (event.organizer and event.organizer.id == app.user.id) or event.hasEnded() ? 'disabled' : '' }}>
                            {{ event.hasEnded() ? 'Event ended' : (event.full ? 'Event full' : (event.price > 0 ? 'Pay & join' : 'Register')) }}
                        </button>
                    </form>
                    {% if not event.price > 0 %}
                        <form method="post" action="{{ path('app_event_unregister', {id: event.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('unregister' ~ event.id) }}">
                            <button class="btn btn-secondary w-100 w-sm-auto" type="submit">Unregister</button>
                        </form>
                    {% endif %}
                </div>
            </div>
        {% endif %}
    </div>

    <div class="col-lg-4 mt-3 mt-lg-0">
        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="h5">Participants</h2>
                <ul class="list-group list-group-flush">
                    {% for attendee in event.attendees %}
                        <li class="list-group-item">{{ attendee.firstName }} {{ attendee.lastName }}</li>
                    {% else %}
                        <li class="list-group-item">No participants yet.</li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    </div>
</div>
{% endblock %}